datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  name      String
  avatarUrl String?
  currency  String   @default("USD")
  language  String   @default("en")
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedGroups           Group[]        @relation("GroupOwner")
  participations        GroupMember[]
  expensesPaid          Expense[]      @relation("ExpensePayer")
  debtShares            ExpenseSplit[]
  settlementsAsPayer    Settlement[]   @relation("SettlementPayer")
  settlementsAsReceiver Settlement[]   @relation("SettlementReceiver")
  activities            Activity[]
  notifications         Notification[]
  sentInvites           Invite[]       @relation("InviteSender")
  receivedInvites       Invite[]       @relation("InviteReceiver")

  @@map("users")
}

model Category {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String    @unique
  icon     String?
  expenses Expense[]

  @@map("categories")
}

model Group {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  currency    String   @default("USD")
  ownerId     String   @db.ObjectId
  owner       User     @relation("GroupOwner", fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  activities  Activity[]
  invites     Invite[]

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId  String   @db.ObjectId
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String   @db.ObjectId
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
  @@map("group_members")
}

model Expense {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  groupId     String    @db.ObjectId
  group       Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payerId     String    @db.ObjectId
  payer       User      @relation("ExpensePayer", fields: [payerId], references: [id], onDelete: Cascade)
  categoryId  String?   @db.ObjectId
  category    Category? @relation(fields: [categoryId], references: [id])
  amountCents Int
  description String
  notes       String?
  receiptUrl  String?
  createdAt   DateTime  @default(now())

  splits ExpenseSplit[]

  @@index([groupId])
  @@index([payerId])
  @@map("expenses")
}

model ExpenseSplit {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  expenseId   String  @db.ObjectId
  expense     Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId      String  @db.ObjectId
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountCents Int

  @@unique([expenseId, userId])
  @@map("expense_splits")
}

model Settlement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId     String   @db.ObjectId
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payerId     String   @db.ObjectId
  payer       User     @relation("SettlementPayer", fields: [payerId], references: [id], onDelete: Cascade)
  receiverId  String   @db.ObjectId
  receiver    User     @relation("SettlementReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  amountCents Int
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([groupId])
  @@index([payerId])
  @@map("settlements")
}

model Activity {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId   String?  @db.ObjectId
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // expense_added | member_joined | settlement_verified | group_created
  meta      Json?
  createdAt DateTime @default(now())

  @@index([groupId])
  @@index([userId])
  @@map("activities")
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

model Invite {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  groupId    String   @db.ObjectId
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId   String   @db.ObjectId
  sender     User     @relation("InviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String?  @db.ObjectId
  receiver   User?    @relation("InviteReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  email      String
  token      String   @unique
  status     String   @default("pending") // pending | accepted | declined
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([groupId])
  @@map("invites")
}
